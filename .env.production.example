# ==============================
# 生产环境变量模板
# 说明：
# 1) 仅用于示例，请勿提交真实密钥
# 2) 建议在部署平台 Secret 管理中配置真实值
# ==============================

# ------------------------------
# 必需变量（Required）
# ------------------------------
# LLM API 密钥
LLM_API_KEY=sk-your-production-llm-api-key
# LLM API 地址（OpenAI 兼容）
LLM_BASE_URL=https://api.openai.com/v1
# Apify API Token
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------
# 可选变量（Optional）
# ------------------------------
# 运行环境（默认：production）
APP_ENV=production
# 日志级别（默认：INFO）
LOG_LEVEL=INFO

# ------------------------------
# 可选扩展变量（按需覆盖默认值）
# ------------------------------
# LLM 提供商（默认：openai-compatible）
LLM_PROVIDER=openai-compatible
# LLM 模型（默认：glm-5）
LLM_MODEL=glm-5
