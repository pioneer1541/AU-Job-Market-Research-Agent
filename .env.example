# ==============================
# LLM 配置
# ==============================
# LLM 提供商（默认：openai-compatible）
LLM_PROVIDER=openai-compatible
# LLM 模型名称（默认：glm-5）
LLM_MODEL=glm-5
# [必需] LLM API 密钥（示例值，请替换为真实密钥）
LLM_API_KEY=sk-your-llm-api-key
# [必需] LLM API 地址（OpenAI 兼容格式）
LLM_BASE_URL=https://api.openai.com/v1

# ==============================
# Apify 配置
# ==============================
# [必需] Apify API Token（示例值，请替换为真实 Token）
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================
# 应用运行配置
# ==============================
# 应用环境（可选，默认：development，可选值：development/production）
APP_ENV=development
# 日志级别（可选，默认：INFO，可选值：DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 前端 API 请求超时（秒，可选，默认：300）
# Apify 抓取 + LLM 分析可能需要 3-5 分钟，建议保持 >= 300
FRONTEND_API_TIMEOUT=300
